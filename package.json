{
  "name": "trustchain-backend",
  "version": "2.2.1",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "start": "npm-run-all --parallel start:server start:gateway",
    "start:server": "node dist/server.js",
    "start:gateway": "node dist/hono_edge.js",
    "dev": "npm-run-all --parallel dev:server dev:gateway",
    "dev:server": "tsx server.ts",
    "dev:gateway": "tsx hono_edge.ts",
    "build": "npx tsc",
    "vercel-build": "npx tsc"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.29.0",
    "@hono/node-server": "^1.19.11",
    "@solana/web3.js": "^1.98.4",
    "@triton-one/yellowstone-grpc": "^5.0.3",
    "axios": "^1.6.8",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "hono": "^4.12.4",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.33",
    "npm-run-all": "^4.1.5",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  }
}
